# ── 必需（主模型） ──────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── 必需（飞书 CRM） ───────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret

# ── 可选（车膜改色生图 provider 链） ─────────────────────
# 如果要用改色预览功能，至少配一个生图 provider
WRAP_PROVIDER_CHAIN=4sapi_primary,apiyi_primary,xinghu_third,relay_backup

# 4sapi（推荐首选）
WRAP_PROVIDER_4SAPI_PRIMARY_API_KEY=

# APIYi（备选）
WRAP_PROVIDER_APIYI_PRIMARY_API_KEY=

# 星狐（备选）
WRAP_PROVIDER_XINGHU_THIRD_API_KEY=

# ── 可选（辅助模型） ────────────────────────────────────────
# 如果不配置，Hermes 会自动使用主模型做辅助任务
# OPENROUTER_API_KEY=
# GOOGLE_API_KEY=

# ── 可选（飞书 gateway） ──────────────────────────────────
# FEISHU_DOMAIN=feishu
# FEISHU_HOME_CHANNEL=oc_xxxxxxxxxxx
# FEISHU_ALLOWED_USERS=ou_xxxxxxxxxxx,ou_xxxxxxxxxxx
